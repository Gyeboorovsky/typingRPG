{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Typing RPG",
  "version": "0.1.0",
  "identifier": "com.gyeboorovsky.typingrpg",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5199",
    "beforeDevCommand": "npm run dev -- --port 5199 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Typing RPG",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
